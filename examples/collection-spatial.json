{
  "type": "Collection",
  "stac_version": "1.0.0",
  "stac_extensions": [
    "https://stac-extensions.github.io/table/v1.2.0/schema.json",
    "https://portolan-sdi.github.io/stac-osi-extension/v0.1.0/schema.json"
  ],
  "id": "population-by-h3",
  "title": "Population by H3 cell",
  "description": "Gridded population counts keyed by H3 cell, demonstrating the OSI spatial column descriptor on a geospatial collection.",
  "license": "CC-BY-4.0",
  "osi:version": "1.0.0",
  "osi:metrics": [
    {
      "name": "total_population",
      "description": "Total population summed across the selected H3 cells."
    }
  ],
  "table:columns": [
    {
      "name": "h3",
      "type": "string",
      "description": "H3 cell index at resolution 8.",
      "osi:spatial": {
        "geometry_type": "polygon",
        "srid": 4326,
        "spatial_index": {
          "system": "h3",
          "resolution": 8
        }
      }
    },
    {
      "name": "geom",
      "type": "binary",
      "description": "Cell boundary geometry, WKB encoded.",
      "osi:spatial": {
        "geometry_type": "polygon",
        "srid": 4326
      }
    },
    {
      "name": "population",
      "type": "int64",
      "description": "Resident population count for the cell."
    }
  ],
  "extent": {
    "spatial": {
      "bbox": [[-180, -90, 180, 90]]
    },
    "temporal": {
      "interval": [["2020-01-01T00:00:00Z", "2020-12-31T23:59:59Z"]]
    }
  },
  "assets": {
    "data": {
      "href": "https://example-bucket.s3.eu-north-1.amazonaws.com/population-by-h3/population.parquet",
      "type": "application/vnd.apache.parquet",
      "roles": ["data"],
      "title": "Population by H3, GeoParquet"
    },
    "semantic-model": {
      "href": "./model.osi.yaml",
      "type": "application/yaml",
      "roles": ["osi", "semantic-model"],
      "title": "OSI semantic model"
    }
  },
  "links": [
    {
      "rel": "root",
      "href": "../catalog.json",
      "type": "application/json"
    },
    {
      "rel": "self",
      "href": "./collection.json",
      "type": "application/json"
    }
  ]
}
