{
  "type": "Collection",
  "stac_version": "1.0.0",
  "stac_extensions": [
    "https://stac-extensions.github.io/table/v1.2.0/schema.json",
    "https://portolan-sdi.github.io/stac-osi-extension/v0.1.1/schema.json"
  ],
  "id": "eurostat-electricity-prices",
  "title": "Industrial electricity prices by country",
  "description": "Half-yearly industrial electricity prices in EUR per kWh by European country. A non-geospatial tabular collection carrying an OSI semantic model.",
  "license": "CC-BY-4.0",
  "portolan:geospatial": false,
  "osi:version": "1.0.0",
  "osi:metrics": [
    {
      "name": "avg_price_eur_kwh",
      "description": "Average industrial electricity price in EUR per kWh across the selected period and countries."
    }
  ],
  "table:columns": [
    {
      "name": "geo",
      "type": "string",
      "description": "Country code, ISO-3166-1 alpha-2."
    },
    {
      "name": "period",
      "type": "string",
      "description": "Reporting half-year, for example 2024-S1."
    },
    {
      "name": "price_eur_kwh",
      "type": "double",
      "description": "Industrial electricity price in EUR per kWh."
    }
  ],
  "extent": {
    "spatial": {
      "bbox": [[-25, 34, 45, 72]]
    },
    "temporal": {
      "interval": [["2007-01-01T00:00:00Z", "2024-12-31T23:59:59Z"]]
    }
  },
  "assets": {
    "data": {
      "href": "https://example-bucket.s3.eu-north-1.amazonaws.com/eurostat-electricity-prices/electricity-prices.parquet",
      "type": "application/vnd.apache.parquet",
      "roles": ["data"],
      "title": "Electricity prices, Parquet"
    },
    "semantic-model": {
      "href": "./model.osi.yaml",
      "type": "application/yaml",
      "roles": ["osi", "semantic-model"],
      "title": "OSI semantic model"
    }
  },
  "links": [
    {
      "rel": "root",
      "href": "../catalog.json",
      "type": "application/json"
    },
    {
      "rel": "self",
      "href": "./collection.json",
      "type": "application/json"
    },
    {
      "rel": "osi-semantic-model",
      "href": "./model.osi.yaml",
      "type": "application/yaml",
      "title": "OSI semantic model"
    }
  ]
}
